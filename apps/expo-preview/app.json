{
  "expo": {
    "name": "Verdant Pay",
    "slug": "verdant-pay",
    "version": "1.0.0",
    "scheme": "verdant-pay",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.intentform.verdantpay"
    },
    "android": {
      "package": "dev.intentform.verdant_pay"
    }
  }
}
