# Optional server-side deployment setting only. Judges and browser users must
# not provide a personal key; the app works in deterministic replay mode without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Demo protection. Values are per-process for the Build Week deployment.
INTENTFORM_DAILY_BUDGET=120
INTENTFORM_SESSION_LIMIT=8

# Local-only, legally gated presentation capability. Never enable in hosted builds.
INTENTFORM_ENABLE_LOCAL_BEZELS=0

# Optional authenticated localhost MCP HTTP transport. Leave empty to keep it off.
# Generate a private value locally; never commit a populated value.
INTENTFORM_MCP_TOKEN=
INTENTFORM_MCP_PORT=47831

# Submission readiness (Judge Mode panel). Optional HTTPS URLs; unset values
# report honestly as "Placeholder only" instead of claiming completion.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_DEMO_VIDEO_URL=
NEXT_PUBLIC_DEVPOST_URL=
